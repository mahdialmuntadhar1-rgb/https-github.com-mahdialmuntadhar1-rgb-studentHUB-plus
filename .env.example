# GEMINI_API_KEY: Required for live Gemini AI API calls.
# Without it, local dev uses the built-in DRY_RUN/offline advisor fallback.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT_SECRET: Required in production for signing auth tokens.
# AUTH_TOKEN_SECRET remains supported for older local setups.
JWT_SECRET="replace-with-a-long-random-secret"
AUTH_TOKEN_SECRET="replace-with-a-long-random-secret"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# External backend API for frontend builds.
# Safe default in code is https://rafid-api.mahdialmuntadhar1.workers.dev.
VITE_API_URL="https://rafid-api.mahdialmuntadhar1.workers.dev"

# Production image uploads must use durable object storage, not local disk.
# Cloudflare R2 bucket binding should be named UPLOADS and bucket_name rafid-uploads.
R2_PUBLIC_BASE_URL=

# Email/outreach must remain dry-run until unsubscribe handling and explicit send approval are complete.
RESEND_API_KEY=
DRY_RUN_AUTOMATION=true
DRY_RUN_EMAILS=true
DRY_RUN=true
