# ============================================================================
# JAMIAATI / STUDENTHUB PLUS - ENVIRONMENT VARIABLES
# ============================================================================

# ============================================================================
# CLOUDFLARE WORKER SECRETS (Set via: wrangler secret put <NAME>)
# ============================================================================

# JWT_SECRET: Secret key for JWT token signing (generate a strong random string)
# Command: wrangler secret put JWT_SECRET
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# RESEND_API_KEY: API key for Resend email service (for password reset emails)
# Get from: https://resend.com/api-keys
# Command: wrangler secret put RESEND_API_KEY
RESEND_API_KEY="your-resend-api-key"

# PASSWORD_RESET_FROM_EMAIL: Sender email for password reset emails
# Must be verified in Resend dashboard
# Command: wrangler secret put PASSWORD_RESET_FROM_EMAIL
PASSWORD_RESET_FROM_EMAIL="noreply@yourdomain.com"

# ============================================================================
# OPTIONAL: GEMINI AI API (For AI Academic Mentor feature)
# ============================================================================

# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ============================================================================
# LOCAL DEVELOPMENT (Express server)
# ============================================================================

# APP_URL: The URL where this app is hosted (for local dev, use http://localhost:3000)
APP_URL="http://localhost:3000"

# VITE_BACKEND_URL: Backend API URL for frontend (defaults to production Worker)
# For local dev with Express server: http://localhost:3000
# For production: https://rafid-api.mahdialmuntadhar1.workers.dev
VITE_BACKEND_URL="http://localhost:3000"

# ============================================================================
# CLOUDFLARE D1 & R2 CONFIGURATION
# ============================================================================

# These are configured in wrangler.toml, not here:
# - D1 database binding: DB -> rafid-db
# - R2 bucket binding: R2 -> rafid-uploads

# ============================================================================
# DEPLOYMENT INSTRUCTIONS
# ============================================================================

# 1. Install dependencies:
#    npm install
#
# 2. Install Wrangler CLI:
#    npm install -g wrangler
#
# 3. Login to Cloudflare:
#    wrangler login
#
# 4. Create D1 database:
#    wrangler d1 create rafid-db
#    (Copy the database_id and update wrangler.toml)
#
# 5. Create R2 bucket:
#    wrangler r2 bucket create rafid-uploads
#
# 6. Set secrets:
#    wrangler secret put JWT_SECRET
#    wrangler secret put RESEND_API_KEY
#    wrangler secret put PASSWORD_RESET_FROM_EMAIL
#
# 7. Run database migrations:
#    wrangler d1 execute rafid-db --file=./schema.sql
#
# 8. Deploy Worker:
#    wrangler deploy
#
# 9. Deploy frontend (build and upload to your hosting):
#    npm run build
#    (Upload dist/ folder to your hosting provider)
