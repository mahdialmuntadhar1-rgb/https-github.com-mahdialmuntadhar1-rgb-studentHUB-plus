# Jamiaati / StudentHUB Plus Environment Variables

# REQUIRED FOR CLOUDFLARE WORKER DEPLOYMENT
# ===========================================

# JWT_SECRET: Required for authentication tokens
# Generate a secure random string (32+ characters)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# MESSAGE_ENCRYPTION_KEY: Required for encrypting private messages
# Generate a secure random string (32+ characters)
MESSAGE_ENCRYPTION_KEY="your-super-secret-encryption-key-min-32-chars"

# OPTIONAL FOR EMAIL FEATURES
# ===========================

# RESEND_API_KEY: For password reset emails (optional)
# Get from https://resend.com/api-keys
RESEND_API_KEY=""

# PASSWORD_RESET_FROM_EMAIL: Sender email for password resets (optional)
PASSWORD_RESET_FROM_EMAIL="noreply@yourdomain.com"

# LOCAL DEVELOPMENT
# ==================

# GEMINI_API_KEY: For AI-powered content scraping (optional for local dev)
GEMINI_API_KEY=""

# APP_URL: Local development URL
APP_URL="http://localhost:3000"
