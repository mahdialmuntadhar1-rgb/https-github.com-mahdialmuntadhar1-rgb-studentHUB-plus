{
    "name": "react-example",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "test": "vitest",
        "test:ui": "vitest --ui",
        "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
        "dev": "vite",
        "start": "node dist/server.cjs"
    },
    "dependencies": {
        "@google/genai": "^2.4.0",
        "@tailwindcss/vite": "^4.1.14",
        "@vitejs/plugin-react": "^5.0.4",
        "bcrypt": "6.0.0",
        "dotenv": "17.4.2",
        "express": "^4.21.2",
        "express-session": "1.19.0",
        "lucide-react": "^0.546.0",
        "motion": "^12.23.24",
        "passport": "0.7.0",
        "passport-local": "1.0.0",
        "pg": "8.21.0",
        "react": "^19.0.1",
        "react-dom": "^19.0.1",
        "vite": "^6.2.3",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@types/bcrypt": "6.0.0",
        "@types/express": "^4.17.21",
        "@types/express-session": "1.19.0",
        "@types/node": "^22.14.0",
        "@types/passport": "1.0.17",
        "@types/passport-local": "1.0.38",
        "@types/pg": "8.20.0",
        "autoprefixer": "^10.4.21",
        "esbuild": "^0.25.0",
        "tailwindcss": "^4.1.14",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "vite": "^6.2.3"
    }
}
