{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "worker:dev": "wrangler dev --config wrangler.api.toml",
    "worker:deploy": "wrangler deploy --config wrangler.api.toml",
    "hero:db:migrate": "wrangler d1 execute rafid-db --remote --file=./migrations/0001_hero_images.sql --config wrangler.api.toml",
    "hero:admin:grant": "wrangler d1 execute rafid-db --remote --file=./migrations/0002_grant_hero_admin.sql --config wrangler.api.toml",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "hono": "^4.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "2.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^3.0.0"
  }
}
